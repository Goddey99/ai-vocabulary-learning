# Secrets and local environment files should never be committed because they may contain API keys or machine-specific settings.
.env

# Local virtual environments are developer-specific and can be large, platform-dependent, and reproducible from requirements.txt.
.venv/

# Python bytecode caches are generated automatically at runtime and should not be versioned.
__pycache__/
*.pyc

# Pytest cache is generated locally during test runs and should not be shared in Git.
.pytest_cache/

# Generated assets are reproducible outputs and can be regenerated by the application, so they should stay out of source control.
generated/